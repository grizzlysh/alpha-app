  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")
  createdById        Int?              @map("created_by_id")
  updatedById        Int?              @map("updated_by_id")
  deletedById        Int?              @map("deleted_by_id")

  pharmacy      Pharmacy            @relation(fields: [pharmacyId], references: [id])
  distributor   Distributor         @relation(fields: [distributorId], references: [id])
  signedByUser  User?               @relation("StockReturnSignedBy", fields: [signedById], references: [id])
  createdByUser User?               @relation("StockReturnCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?               @relation("StockReturnUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?               @relation("StockReturnDeletedBy", fields: [deletedById], references: [id])
  details       StockReturnDetail[]

  @@map("trx_stock_returns")
}

model StockReturnDetail {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique @default(uuid())
  stockReturnId  Int      @map("stock_return_id")
  medicineId     Int      @map("medicine_id")
  stockDetailId  Int      @map("stock_detail_id")
  quantityPieces Int      @map("quantity_pieces")
  quantityBox    Int      @map("quantity_box")
  price          Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdById    Int?     @map("created_by_id")
  updatedById    Int?     @map("updated_by_id")

  stockReturn    StockReturn     @relation(fields: [stockReturnId], references: [id])
  medicine       Medicine        @relation(fields: [medicineId], references: [id])
  stockDetail    StockDetail     @relation(fields: [stockDetailId], references: [id])
  createdByUser  User?           @relation("StockReturnDetailCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?           @relation("StockReturnDetailUpdatedBy", fields: [updatedById], references: [id])
  stockMovements StockMovement[]

  @@map("trx_stock_return_details")
}

// ── TRX STOCK DISPOSAL ───────────────────────────────────

model StockDisposal {
  id                 Int                 @id @default(autoincrement())
  uuid               String              @unique @default(uuid())
  pharmacyId         Int                 @map("pharmacy_id")
  signedById         Int?                @map("signed_by_id")
  disposalNumber     String              @unique @map("disposal_number")
  status             StockDisposalStatus @default(DRAFT)
  description        String?
  cancellationReason String?             @map("cancellation_reason")
  disposedAt         DateTime?           @map("disposed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  createdById        Int?                @map("created_by_id")
  updatedById        Int?                @map("updated_by_id")
  deletedById        Int?                @map("deleted_by_id")

  pharmacy      Pharmacy              @relation(fields: [pharmacyId], references: [id])
  signedByUser  User?                 @relation("StockDisposalSignedBy", fields: [signedById], references: [id])
  createdByUser User?                 @relation("StockDisposalCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?                 @relation("StockDisposalUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?                 @relation("StockDisposalDeletedBy", fields: [deletedById], references: [id])
  details       StockDisposalDetail[]

  @@map("trx_stock_disposals")
}

model StockDisposalDetail {
  id              Int            @id @default(autoincrement())
  uuid            String         @unique @default(uuid())
  stockDisposalId Int            @map("stock_disposal_id")
  medicineId      Int            @map("medicine_id")
  stockDetailId   Int            @map("stock_detail_id")
  quantityPieces  Int            @map("quantity_pieces")
  quantityBox     Int            @map("quantity_box")
  reason          DisposalReason
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  createdById     Int?           @map("created_by_id")
  updatedById     Int?           @map("updated_by_id")

  stockDisposal  StockDisposal   @relation(fields: [stockDisposalId], references: [id])
  medicine       Medicine        @relation(fields: [medicineId], references: [id])
  stockDetail    StockDetail     @relation(fields: [stockDetailId], references: [id])
  createdByUser  User?           @relation("StockDisposalDetailCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?           @relation("StockDisposalDetailUpdatedBy", fields: [updatedById], references: [id])
  stockMovements StockMovement[]

  @@map("trx_stock_disposal_details")
}

// ── TRX SALES ────────────────────────────────────────────

model Sale {
  id                 Int        @id @default(autoincrement())
  uuid               String     @unique @default(uuid())
  pharmacyId         Int        @map("pharmacy_id")
  customerId         Int        @map("customer_id")
  prescriptionId     Int?       @unique @map("prescription_id")
  saleNumber         String     @unique @map("sale_number")
  saleType           SaleType   @default(CASH) @map("sale_type")
  status             SaleStatus @default(COMPLETED)
  totalAmount        Decimal    @map("total_amount") @db.Decimal(12, 2)
  discountPercentage Decimal    @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  discountAmount     Decimal    @default(0) @map("discount_amount") @db.Decimal(12, 2)
  ppnPercentage      Decimal    @default(0) @map("ppn_percentage") @db.Decimal(5, 2)
  ppnAmount          Decimal    @default(0) @map("ppn_amount") @db.Decimal(12, 2)
  grandTotal         Decimal    @map("grand_total") @db.Decimal(12, 2)
  paidAmount         Decimal    @default(0) @map("paid_amount") @db.Decimal(12, 2)
  dueDate            DateTime?  @map("due_date")
  description        String?
  soldAt             DateTime   @default(now()) @map("sold_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")
  createdById        Int?       @map("created_by_id")
  updatedById        Int?       @map("updated_by_id")
  deletedById        Int?       @map("deleted_by_id")

  pharmacy              Pharmacy      @relation(fields: [pharmacyId], references: [id])
  customer              Customer      @relation(fields: [customerId], references: [id])
  prescription          Prescription? @relation("SaleSourcePrescription", fields: [prescriptionId], references: [id])
  dispensedPrescription Prescription? @relation("PrescriptionDispensedSale")
  createdByUser         User?         @relation("SaleCreatedBy", fields: [createdById], references: [id])
  updatedByUser         User?         @relation("SaleUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser         User?         @relation("SaleDeletedBy", fields: [deletedById], references: [id])
  details               SaleDetail[]
  payment               SalePayment?
  reservations          StockReservation[]

  @@map("trx_sales")
}

model SaleDetail {
  id                 Int      @id @default(autoincrement())
  uuid               String   @unique @default(uuid())
  saleId             Int      @map("sale_id")
  medicineId         Int      @map("medicine_id")
  stockDetailId      Int      @map("stock_detail_id")
  quantityPieces     Int      @map("quantity_pieces")
  quantityBox        Int      @map("quantity_box")
  isFefoOverride     Boolean  @default(false) @map("is_fefo_override")
  sellingPrice       Decimal  @map("selling_price") @db.Decimal(12, 2)
  originalPrice      Decimal  @default(0) @map("original_price") @db.Decimal(12, 2)
  discountPercentage Decimal  @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  discountAmount     Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount        Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  createdById        Int?     @map("created_by_id")
  updatedById        Int?     @map("updated_by_id")

  sale           Sale            @relation(fields: [saleId], references: [id])
  medicine       Medicine        @relation(fields: [medicineId], references: [id])
  stockDetail    StockDetail     @relation(fields: [stockDetailId], references: [id])
  createdByUser  User?           @relation("SaleDetailCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?           @relation("SaleDetailUpdatedBy", fields: [updatedById], references: [id])
  stockMovements StockMovement[]

  @@map("trx_sale_details")
}

model SalePayment {
  id            Int           @id @default(autoincrement())
  uuid          String        @unique @default(uuid())
  saleId        Int           @unique @map("sale_id")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdById   Int?          @map("created_by_id")
  updatedById   Int?          @map("updated_by_id")

  sale          Sale                 @relation(fields: [saleId], references: [id])
  createdByUser User?                @relation("SalePaymentCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?                @relation("SalePaymentUpdatedBy", fields: [updatedById], references: [id])
  history       SalePaymentHistory[]

  @@map("trx_sale_payments")
}

model SalePaymentHistory {
  id            Int           @id @default(autoincrement())
  uuid          String        @unique @default(uuid())
  salePaymentId Int           @map("sale_payment_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentDate   DateTime      @map("payment_date")
  description   String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdById   Int?          @map("created_by_id")
  updatedById   Int?          @map("updated_by_id")

  salePayment   SalePayment @relation(fields: [salePaymentId], references: [id])
  createdByUser User?       @relation("SalePaymentHistoryCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?       @relation("SalePaymentHistoryUpdatedBy", fields: [updatedById], references: [id])

  @@map("trx_sale_payment_history")
}

// ── MST DOCTOR ───────────────────────────────────────────

model Doctor {
  id            Int          @id @default(autoincrement())
  uuid          String       @unique @default(uuid())
  pharmacyId    Int          @map("pharmacy_id")
  userId        Int?         @unique @map("user_id")
  name          String
  licenseNumber String?      @map("license_number")
  specialty     String?
  clinicName    String?      @map("clinic_name")
  phone         String?
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")
  createdById   Int?         @map("created_by_id")
  updatedById   Int?         @map("updated_by_id")
  deletedById   Int?         @map("deleted_by_id")

  pharmacy      Pharmacy       @relation(fields: [pharmacyId], references: [id])
  user          User?          @relation("DoctorUserProfile", fields: [userId], references: [id])
  prescriptions Prescription[]
  createdBy     User?          @relation("DoctorCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?          @relation("DoctorUpdatedBy", fields: [updatedById], references: [id])
  deletedBy     User?          @relation("DoctorDeletedBy", fields: [deletedById], references: [id])

  @@unique([pharmacyId, licenseNumber])
  @@map("mst_doctors")
}

// ── TRX PRESCRIPTION ─────────────────────────────────────

model Prescription {
  id                 Int                @id @default(autoincrement())
  uuid               String             @unique @default(uuid())
  pharmacyId         Int                @map("pharmacy_id")
  customerId         Int                @map("customer_id")
  saleId             Int?               @unique @map("sale_id")
  doctorId           Int?               @map("doctor_id")
  prescriptionNumber String?            @map("prescription_number")
  prescribedAt       DateTime           @map("prescribed_at")
  notes              String?
  status             PrescriptionStatus @default(PENDING)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById Int?      @map("created_by_id")
  updatedById Int?      @map("updated_by_id")
  deletedById Int?      @map("deleted_by_id")

  pharmacy   Pharmacy             @relation(fields: [pharmacyId], references: [id])
  customer   Customer             @relation(fields: [customerId], references: [id])
  sale       Sale?                @relation("PrescriptionDispensedSale", fields: [saleId], references: [id])
  doctor     Doctor?              @relation(fields: [doctorId], references: [id])
  createdBy  User?                @relation("PrescriptionCreatedBy", fields: [createdById], references: [id])
  updatedBy  User?                @relation("PrescriptionUpdatedBy", fields: [updatedById], references: [id])
  deletedBy  User?                @relation("PrescriptionDeletedBy", fields: [deletedById], references: [id])
  details    PrescriptionDetail[]
  sourceSale Sale?                @relation("SaleSourcePrescription")

  @@map("trx_prescriptions")
}

model PrescriptionDetail {
  id             Int                      @id @default(autoincrement())
  uuid           String                   @unique @default(uuid())
  prescriptionId Int                      @map("prescription_id")
  medicineId     Int?                     @map("medicine_id") // nullable if not in system
  medicineName   String                   @map("medicine_name") // what doctor wrote
  frequency      String? // e.g. "3x1"
  duration       String? // e.g. "10 hari"
  qty            Int // ordered qty
  dispensedQty   Int                      @default(0) @map("dispensed_qty") // actually given
  notes          String?
  status         PrescriptionDetailStatus @default(PENDING)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById Int?      @map("created_by_id")
  updatedById Int?      @map("updated_by_id")
  deletedById Int?      @map("deleted_by_id")

  prescription Prescription @relation(fields: [prescriptionId], references: [id])
  medicine     Medicine?    @relation(fields: [medicineId], references: [id])
  createdBy    User?        @relation("PrescriptionDetailCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?        @relation("PrescriptionDetailUpdatedBy", fields: [updatedById], references: [id])
  deletedBy    User?        @relation("PrescriptionDetailDeletedBy", fields: [deletedById], references: [id])

  @@map("trx_prescription_details")
}

// ── SYS IDEMPOTENCY KEYS ─────────────────────────────────

model IdempotencyKey {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  statusCode   Int      @map("status_code")
  responseBody Json     @map("response_body")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@map("sys_idempotency_keys")
}
