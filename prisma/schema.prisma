generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ────────────────────────────────────────────────

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum PlatformRole {
  PLATFORM_ADMIN
  PLATFORM_VIEWER
  PLATFORM_SUPPORT
}

enum AppRole {
  OWNER
  ADMIN
  PHARMACIST
  HEAD_PHARMACIST
  CASHIER
  DOCTOR
}

enum PharmacyCategory {
  APOTEK
  KLINIK
  RUMAH_SAKIT
  PUSKESMAS
}

enum DataType {
  STRING
  NUMBER
  BOOLEAN
  PERCENTAGE
}

enum StockMovementType {
  IN
  OUT
}

enum StockMovementReason {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  DISPOSAL
  DAMAGED
  TRANSFER
  DONATION
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  // PARTIAL
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT
}

enum StockReturnStatus {
  IN_PROCESS
  COMPLETED
  CANCELLED
  REJECTED
}

enum StockDisposalStatus {
  DRAFT
  SUBMITTED
  COMPLETED
  CANCELLED
}

enum DisposalReason {
  EXPIRED
  DAMAGED
  CONTAMINATED
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum SaleType {
  CASH
  CREDIT
}

enum PrescriptionStatus {
  PENDING // received, not yet dispensed
  DISPENSED // fully dispensed
  PARTIAL // partially dispensed
  CANCELLED // rejected or withdrawn
  EXPIRED // too old to dispense
}

enum PrescriptionDetailStatus {
  PENDING // not yet dispensed
  DISPENSED // fully given
  PARTIAL // partially given (dispensedQty < qty)
  CANCELLED // removed from prescription
}

// ── MST SYSTEM ───────────────────────────────────────────

model SystemParameter {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  key         String   @unique
  value       String
  dataType    DataType @map("data_type")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")
  updatedById Int?     @map("updated_by_id")

  createdByUser User? @relation("SystemParameterCreatedBy", fields: [createdById], references: [id])
  updatedByUser User? @relation("SystemParameterUpdatedBy", fields: [updatedById], references: [id])

  @@map("mst_system_parameters")
}

model BusinessParameter {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  pharmacyId  Int      @map("pharmacy_id")
  key         String
  value       String
  dataType    DataType @map("data_type")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")
  updatedById Int?     @map("updated_by_id")

  pharmacy      Pharmacy @relation(fields: [pharmacyId], references: [id])
  createdByUser User?    @relation("BusinessParameterCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?    @relation("BusinessParameterUpdatedBy", fields: [updatedById], references: [id])

  @@unique([pharmacyId, key])
  @@map("mst_business_parameters")
}

model Role {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(uuid())
  pharmacyId      Int?         @map("pharmacy_id")
  name            String
  type            AppRole
  description     String?
  requiresLicense Boolean      @default(false) @map("requires_license")
  status          RecordStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdById     Int?         @map("created_by_id")
  updatedById     Int?         @map("updated_by_id")
  deletedById     Int?         @map("deleted_by_id")

  pharmacy        Pharmacy?        @relation(fields: [pharmacyId], references: [id])
  rolePermissions RolePermission[]
  placements      Placement[]
  createdByUser   User?            @relation("RoleCreatedBy", fields: [createdById], references: [id])
  updatedByUser   User?            @relation("RoleUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser   User?            @relation("RoleDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")
  updatedById Int?     @map("updated_by_id")

  rolePermissions RolePermission[]
  createdByUser   User?            @relation("PermissionCreatedBy", fields: [createdById], references: [id])
  updatedByUser   User?            @relation("PermissionUpdatedBy", fields: [updatedById], references: [id])

  @@unique([module, action])
  @@map("mst_permissions")
}

model RolePermission {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  roleId       Int      @map("role_id")
  permissionId Int      @map("permission_id")
  pharmacyId   Int?     @map("pharmacy_id")
  isEnabled    Boolean  @default(true) @map("is_enabled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdById  Int?     @map("created_by_id")
  updatedById  Int?     @map("updated_by_id")

  role          Role       @relation(fields: [roleId], references: [id])
  permission    Permission @relation(fields: [permissionId], references: [id])
  pharmacy      Pharmacy?  @relation(fields: [pharmacyId], references: [id])
  createdByUser User?      @relation("RolePermissionCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?      @relation("RolePermissionUpdatedBy", fields: [updatedById], references: [id])

  @@unique([roleId, permissionId, pharmacyId])
  @@map("mst_role_permissions")
}

// ── MST PHARMACY & USER ──────────────────────────────────

model Pharmacy {
  id          Int              @id @default(autoincrement())
  uuid        String           @unique @default(uuid())
  name        String
  code        String           @unique
  category    PharmacyCategory @default(APOTEK)
  address     String
  location    String
  phone       String
  email       String?
  status      RecordStatus     @default(ACTIVE)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  createdById Int?             @map("created_by_id")
  updatedById Int?             @map("updated_by_id")
  deletedById Int?             @map("deleted_by_id")

  lastSelectedByUsers User[]              @relation("UserLastPharmacy")
  createdByUser       User?               @relation("PharmacyCreatedBy", fields: [createdById], references: [id])
  updatedByUser       User?               @relation("PharmacyUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser       User?               @relation("PharmacyDeletedBy", fields: [deletedById], references: [id])
  businessLicenses    BusinessLicense[]
  placements          Placement[]
  medicines           Medicine[]
  distributors        Distributor[]
  customers           Customer[]
  purchaseOrders      PurchaseOrder[]
  invoices            Invoice[]
  stocks              Stock[]
  stockMovements      StockMovement[]
  stockReturns        StockReturn[]
  stockDisposals      StockDisposal[]
  sales               Sale[]
  businessParameters  BusinessParameter[]
  roles               Role[]
  rolePermissions     RolePermission[]
  medicineShapes      MedicineShape[]
  medicineTypes       MedicineType[]
  medicineClasses     MedicineClass[]
  prescriptions       Prescription[]
  stockReservations   StockReservation[]
  storageCabinets     StorageCabinet[]
  doctors             Doctor[]

  @@map("mst_pharmacies")
}

model User {
  id                     Int           @id @default(autoincrement())
  uuid                   String        @unique @default(uuid())
  name                   String
  email                  String        @unique
  password               String
  phone                  String?       @map("phone")
  address                String?       @map("address")
  mustChangePassword     Boolean       @default(false) @map("must_change_password")
  platformRole           PlatformRole? @map("platform_role")
  lastSelectedPharmacyId Int?          @map("last_selected_pharmacy_id")
  failedLoginCount       Int           @default(0) @map("failed_login_count")
  lockedUntil            DateTime?     @map("locked_until")
  status                 RecordStatus  @default(ACTIVE)
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  deletedAt              DateTime?     @map("deleted_at")
  createdById            Int?          @map("created_by_id")
  updatedById            Int?          @map("updated_by_id")
  deletedById            Int?          @map("deleted_by_id")

  // ── Self Relations ────────────────────────────────
  createdByUser User?  @relation("UserCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?  @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?  @relation("UserDeletedBy", fields: [deletedById], references: [id])
  usersCreated  User[] @relation("UserCreatedBy")
  usersUpdated  User[] @relation("UserUpdatedBy")
  usersDeleted  User[] @relation("UserDeletedBy")

  // ── Business Relations ────────────────────────────
  placements           Placement[]
  tokens               UserToken[]
  lastSelectedPharmacy Pharmacy?   @relation("UserLastPharmacy", fields: [lastSelectedPharmacyId], references: [id])
  // purchaseOrders  PurchaseOrder[]
  // invoices        Invoice[]
  // stockReturns    StockReturn[]
  // stockDisposals  StockDisposal[]
  // sales           Sale[]
  // stockMovements  StockMovement[]

  // ── Audit: SystemParameter ────────────────────────
  systemParametersCreated SystemParameter[] @relation("SystemParameterCreatedBy")
  systemParametersUpdated SystemParameter[] @relation("SystemParameterUpdatedBy")

  // ── Audit: BusinessParameter ──────────────────────
  businessParametersCreated BusinessParameter[] @relation("BusinessParameterCreatedBy")
  businessParametersUpdated BusinessParameter[] @relation("BusinessParameterUpdatedBy")

  // ── Audit: Role ───────────────────────────────────
  rolesCreated Role[] @relation("RoleCreatedBy")
  rolesUpdated Role[] @relation("RoleUpdatedBy")
  rolesDeleted Role[] @relation("RoleDeletedBy")

  // ── Audit: Permission ─────────────────────────────
  permissionsCreated Permission[] @relation("PermissionCreatedBy")
  permissionsUpdated Permission[] @relation("PermissionUpdatedBy")

  // ── Audit: RolePermission ─────────────────────────
  rolePermissionsCreated RolePermission[] @relation("RolePermissionCreatedBy")
  rolePermissionsUpdated RolePermission[] @relation("RolePermissionUpdatedBy")

  // ── Audit: Pharmacy ───────────────────────────────
  pharmaciesCreated Pharmacy[] @relation("PharmacyCreatedBy")
  pharmaciesUpdated Pharmacy[] @relation("PharmacyUpdatedBy")
  pharmaciesDeleted Pharmacy[] @relation("PharmacyDeletedBy")

  // ── Audit: UserToken ──────────────────────────────
  userTokensCreated UserToken[] @relation("UserTokenCreatedBy")
  userTokensUpdated UserToken[] @relation("UserTokenUpdatedBy")

  // ── Audit: Placement ───────────────────────────
  placementsCreated Placement[] @relation("PlacementCreatedBy")
  placementsUpdated Placement[] @relation("PlacementUpdatedBy")
  placementsDeleted Placement[] @relation("PlacementDeletedBy")

  // ── Audit: PracticeLicense ────────────────────────
  practiceLicensesCreated PracticeLicense[] @relation("PracticeLicenseCreatedBy")
  practiceLicensesUpdated PracticeLicense[] @relation("PracticeLicenseUpdatedBy")
  practiceLicensesDeleted PracticeLicense[] @relation("PracticeLicenseDeletedBy")

  // ── Audit: BusinessLicense ────────────────────────
  businessLicensesCreated BusinessLicense[] @relation("BusinessLicenseCreatedBy")
  businessLicensesUpdated BusinessLicense[] @relation("BusinessLicenseUpdatedBy")
  businessLicensesDeleted BusinessLicense[] @relation("BusinessLicenseDeletedBy")

  // ── Audit: MedicineShape ──────────────────────────
  medicineShapesCreated MedicineShape[] @relation("MedicineShapeCreatedBy")
  medicineShapesUpdated MedicineShape[] @relation("MedicineShapeUpdatedBy")
  medicineShapesDeleted MedicineShape[] @relation("MedicineShapeDeletedBy")

  // ── Audit: MedicineType ───────────────────────────
  medicineTypesCreated MedicineType[] @relation("MedicineTypeCreatedBy")
  medicineTypesUpdated MedicineType[] @relation("MedicineTypeUpdatedBy")
  medicineTypesDeleted MedicineType[] @relation("MedicineTypeDeletedBy")

  // ── Audit: MedicineClass ──────────────────────────
  medicineClassesCreated MedicineClass[] @relation("MedicineClassCreatedBy")
  medicineClassesUpdated MedicineClass[] @relation("MedicineClassUpdatedBy")
  medicineClassesDeleted MedicineClass[] @relation("MedicineClassDeletedBy")

  // ── Audit: Medicine ───────────────────────────────
  medicinesCreated Medicine[] @relation("MedicineCreatedBy")
  medicinesUpdated Medicine[] @relation("MedicineUpdatedBy")
  medicinesDeleted Medicine[] @relation("MedicineDeletedBy")

  // ── Audit: MedicineIngredient ─────────────────────
  medicineIngredientsCreated MedicineIngredient[] @relation("MedicineIngredientCreatedBy")
  medicineIngredientsUpdated MedicineIngredient[] @relation("MedicineIngredientUpdatedBy")

  // ── Audit: Distributor ────────────────────────────
  distributorsCreated Distributor[] @relation("DistributorCreatedBy")
  distributorsUpdated Distributor[] @relation("DistributorUpdatedBy")
  distributorsDeleted Distributor[] @relation("DistributorDeletedBy")

  // ── Audit: Customer ───────────────────────────────
  customersCreated Customer[] @relation("CustomerCreatedBy")
  customersUpdated Customer[] @relation("CustomerUpdatedBy")
  customersDeleted Customer[] @relation("CustomerDeletedBy")

  // ── Audit: PurchaseOrder ──────────────────────────
  purchaseOrdersCreated PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  purchaseOrdersUpdated PurchaseOrder[] @relation("PurchaseOrderUpdatedBy")
  purchaseOrdersDeleted PurchaseOrder[] @relation("PurchaseOrderDeletedBy")

  // ── Audit: PurchaseOrderDetail ────────────────────
  purchaseOrderDetailsCreated PurchaseOrderDetail[] @relation("PurchaseOrderDetailCreatedBy")
  purchaseOrderDetailsUpdated PurchaseOrderDetail[] @relation("PurchaseOrderDetailUpdatedBy")
  purchaseOrderDetailsDeleted PurchaseOrderDetail[] @relation("PurchaseOrderDetailDeletedBy")

  // ── Audit: Invoice ────────────────────────────────
  invoicesCreated Invoice[] @relation("InvoiceCreatedBy")
  invoicesUpdated Invoice[] @relation("InvoiceUpdatedBy")
  invoicesDeleted Invoice[] @relation("InvoiceDeletedBy")

  // ── Audit: InvoiceDetail ──────────────────────────
  invoiceDetailsCreated InvoiceDetail[] @relation("InvoiceDetailCreatedBy")
  invoiceDetailsUpdated InvoiceDetail[] @relation("InvoiceDetailUpdatedBy")

  // ── Audit: InvoicePayment ─────────────────────────
  invoicePaymentsCreated InvoicePayment[] @relation("InvoicePaymentCreatedBy")
  invoicePaymentsUpdated InvoicePayment[] @relation("InvoicePaymentUpdatedBy")

  // ── Audit: InvoicePaymentHistory ──────────────────
  invoicePaymentHistoriesCreated InvoicePaymentHistory[] @relation("InvoicePaymentHistoryCreatedBy")
  invoicePaymentHistoriesUpdated InvoicePaymentHistory[] @relation("InvoicePaymentHistoryUpdatedBy")

  // ── Audit: Stock ──────────────────────────────────
  stocksCreated Stock[] @relation("StockCreatedBy")
  stocksUpdated Stock[] @relation("StockUpdatedBy")

  // ── Audit: StockDetail ────────────────────────────
  stockDetailsCreated StockDetail[] @relation("StockDetailCreatedBy")
  stockDetailsUpdated StockDetail[] @relation("StockDetailUpdatedBy")

  // ── Audit: StockMovement ──────────────────────────
  stockMovementsCreated StockMovement[] @relation("StockMovementCreatedBy")
  stockMovementsUpdated StockMovement[] @relation("StockMovementUpdatedBy")

  // ── Audit: StockReturn ────────────────────────────
  stockReturnsCreated StockReturn[] @relation("StockReturnCreatedBy")
  stockReturnsUpdated StockReturn[] @relation("StockReturnUpdatedBy")
  stockReturnsDeleted StockReturn[] @relation("StockReturnDeletedBy")

  // ── Audit: StockReturnDetail ──────────────────────
  stockReturnDetailsCreated StockReturnDetail[] @relation("StockReturnDetailCreatedBy")
  stockReturnDetailsUpdated StockReturnDetail[] @relation("StockReturnDetailUpdatedBy")

  // ── Audit: StockDisposal ──────────────────────────
  stockDisposalsCreated StockDisposal[] @relation("StockDisposalCreatedBy")
  stockDisposalsUpdated StockDisposal[] @relation("StockDisposalUpdatedBy")
  stockDisposalsDeleted StockDisposal[] @relation("StockDisposalDeletedBy")

  // ── Audit: StockDisposalDetail ────────────────────
  stockDisposalDetailsCreated StockDisposalDetail[] @relation("StockDisposalDetailCreatedBy")
  stockDisposalDetailsUpdated StockDisposalDetail[] @relation("StockDisposalDetailUpdatedBy")

  // ── Audit: Sale ───────────────────────────────────
  salesCreated Sale[] @relation("SaleCreatedBy")
  salesUpdated Sale[] @relation("SaleUpdatedBy")
  salesDeleted Sale[] @relation("SaleDeletedBy")

  // ── Audit: SaleDetail ─────────────────────────────
  saleDetailsCreated SaleDetail[] @relation("SaleDetailCreatedBy")
  saleDetailsUpdated SaleDetail[] @relation("SaleDetailUpdatedBy")

  // ── Audit: SalePayment ────────────────────────────
  salePaymentsCreated SalePayment[] @relation("SalePaymentCreatedBy")
  salePaymentsUpdated SalePayment[] @relation("SalePaymentUpdatedBy")

  // ── Audit: SalePaymentHistory ─────────────────────
  salePaymentHistoriesCreated SalePaymentHistory[] @relation("SalePaymentHistoryCreatedBy")
  salePaymentHistoriesUpdated SalePaymentHistory[] @relation("SalePaymentHistoryUpdatedBy")

  // ── Audit: StorageCabinet ─────────────────────────
  storageCabinetsCreated StorageCabinet[] @relation("StorageCabinetCreatedBy")
  storageCabinetsUpdated StorageCabinet[] @relation("StorageCabinetUpdatedBy")
  storageCabinetsDeleted StorageCabinet[] @relation("StorageCabinetDeletedBy")

  // ── Audit: StorageShelf ───────────────────────────
  storageShelvesCreated StorageShelf[] @relation("StorageShelfCreatedBy")
  storageShelvesUpdated StorageShelf[] @relation("StorageShelfUpdatedBy")
  storageShelvesDeleted StorageShelf[] @relation("StorageShelfDeletedBy")

  // ── Audit: StorageBin ─────────────────────────────
  storageBinsCreated StorageBin[] @relation("StorageBinCreatedBy")
  storageBinsUpdated StorageBin[] @relation("StorageBinUpdatedBy")
  storageBinsDeleted StorageBin[] @relation("StorageBinDeletedBy")

  // ── Audit: StockReservation ───────────────────────
  stockReservationsCreated StockReservation[] @relation("StockReservationCreatedBy")

  // ── Audit: Doctor ─────────────────────────────────
  doctorProfile  Doctor?   @relation("DoctorUserProfile")
  doctorsCreated Doctor[]  @relation("DoctorCreatedBy")
  doctorsUpdated Doctor[]  @relation("DoctorUpdatedBy")
  doctorsDeleted Doctor[]  @relation("DoctorDeletedBy")

  // ── Audit: Prescription ───────────────────────────
  createdPrescriptions Prescription[] @relation("PrescriptionCreatedBy")
  updatedPrescriptions Prescription[] @relation("PrescriptionUpdatedBy")
  deletedPrescriptions Prescription[] @relation("PrescriptionDeletedBy")

  // ── Audit: PrescriptionDetail ──────────────────────
  createdPrescriptionDetails PrescriptionDetail[] @relation("PrescriptionDetailCreatedBy")
  updatedPrescriptionDetails PrescriptionDetail[] @relation("PrescriptionDetailUpdatedBy")
  deletedPrescriptionDetails PrescriptionDetail[] @relation("PrescriptionDetailDeletedBy")

  // ── Signing ───────────────────────────────────────────
  purchaseOrdersSigned PurchaseOrder[] @relation("PurchaseOrderSignedBy")
  invoicesSigned       Invoice[]       @relation("InvoiceSignedBy")
  stockReturnsSigned   StockReturn[]   @relation("StockReturnSignedBy")
  stockDisposalsSigned StockDisposal[] @relation("StockDisposalSignedBy")

  @@map("mst_users")
}

model UserToken {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  userId       Int      @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdById  Int?     @map("created_by_id")
  updatedById  Int?     @map("updated_by_id")

  user          User  @relation(fields: [userId], references: [id])
  createdByUser User? @relation("UserTokenCreatedBy", fields: [createdById], references: [id])
  updatedByUser User? @relation("UserTokenUpdatedBy", fields: [updatedById], references: [id])

  @@map("mst_user_tokens")
}

model Placement {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  userId      Int          @map("user_id")
  pharmacyId  Int          @map("pharmacy_id")
  roleId      Int          @map("role_id")
  joinedAt    DateTime     @default(now()) @map("joined_at")
  leftAt      DateTime?    @map("left_at")
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdById Int?         @map("created_by_id")
  updatedById Int?         @map("updated_by_id")
  deletedById Int?         @map("deleted_by_id")

  user             User              @relation(fields: [userId], references: [id])
  pharmacy         Pharmacy          @relation(fields: [pharmacyId], references: [id])
  role             Role              @relation(fields: [roleId], references: [id])
  practiceLicenses PracticeLicense[]
  createdByUser    User?             @relation("PlacementCreatedBy", fields: [createdById], references: [id])
  updatedByUser    User?             @relation("PlacementUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser    User?             @relation("PlacementDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_placements")
}

model PracticeLicense {
  id            Int          @id @default(autoincrement())
  uuid          String       @unique @default(uuid())
  placementId   Int          @map("placement_id")
  licenseNumber String       @map("license_number")
  validFrom     DateTime     @map("valid_from")
  validUntil    DateTime     @map("valid_until")
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")
  createdById   Int?         @map("created_by_id")
  updatedById   Int?         @map("updated_by_id")
  deletedById   Int?         @map("deleted_by_id")

  placement     Placement @relation(fields: [placementId], references: [id])
  createdByUser User?     @relation("PracticeLicenseCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?     @relation("PracticeLicenseUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?     @relation("PracticeLicenseDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_practice_licenses")
}

// Pharmacy business license (SIA) — per pharmacy
model BusinessLicense {
  id            Int          @id @default(autoincrement())
  uuid          String       @unique @default(uuid())
  pharmacyId    Int          @map("pharmacy_id")
  licenseNumber String       @map("license_number")
  validFrom     DateTime     @map("valid_from")
  validUntil    DateTime     @map("valid_until")
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")
  createdById   Int?         @map("created_by_id")
  updatedById   Int?         @map("updated_by_id")
  deletedById   Int?         @map("deleted_by_id")

  pharmacy      Pharmacy @relation(fields: [pharmacyId], references: [id])
  createdByUser User?    @relation("BusinessLicenseCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?    @relation("BusinessLicenseUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?    @relation("BusinessLicenseDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_business_licenses")
}

// ── MST STORAGE ──────────────────────────────────────────

model StorageCabinet {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  pharmacyId  Int          @map("pharmacy_id")
  name        String       @db.VarChar(100)
  code        String       @db.VarChar(20)
  description String?      @db.Text
  posX        Float?       @map("pos_x")
  posY        Float?       @map("pos_y")
  width       Float?       @map("width")
  height      Float?       @map("height")
  rotation    Int?         @default(0) @map("rotation")
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdById Int?         @map("created_by_id")
  updatedById Int?         @map("updated_by_id")
  deletedById Int?         @map("deleted_by_id")

  pharmacy      Pharmacy       @relation(fields: [pharmacyId], references: [id])
  createdByUser User?          @relation("StorageCabinetCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?          @relation("StorageCabinetUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?          @relation("StorageCabinetDeletedBy", fields: [deletedById], references: [id])
  shelves       StorageShelf[]

  @@unique([pharmacyId, code])
  @@map("mst_storage_cabinets")
}

model StorageShelf {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  cabinetId   Int          @map("cabinet_id")
  name        String       @db.VarChar(100)
  code        String       @db.VarChar(20)
  level       Int?
  description String?      @db.Text
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdById Int?         @map("created_by_id")
