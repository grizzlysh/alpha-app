generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ────────────────────────────────────────────────

enum RecordStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum PlatformRole {
  PLATFORM_ADMIN
  PLATFORM_VIEWER
  PLATFORM_SUPPORT
}

enum PharmacyRole {
  OWNER
  ADMIN
  PHARMACIST
  CASHIER
}

enum PharmacyCategory {
  APOTEK
  KLINIK
  RUMAH_SAKIT
  PUSKESMAS
}


enum DataType {
  STRING
  NUMBER
  BOOLEAN
  PERCENTAGE
}

enum StockMovementType {
  IN
  OUT
}

enum StockMovementReason {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  DISPOSAL
  DAMAGED
  TRANSFER
  DONATION
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  // PARTIAL
  COMPLETED
  CANCELLED
  // DELETED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT
}

enum StockReturnStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum StockDisposalStatus {
  DRAFT
  SUBMITTED
  COMPLETED
  CANCELLED
}

enum DisposalReason {
  EXPIRED
  DAMAGED
  CONTAMINATED
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

enum SaleType {
  CASH
  CREDIT
}

// ── MST SYSTEM ───────────────────────────────────────────

model SystemParameter {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  key         String   @unique
  value       String
  dataType    DataType @map("data_type")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")
  updatedById Int?     @map("updated_by_id")

  createdByUser User? @relation("SystemParameterCreatedBy", fields: [createdById], references: [id])
  updatedByUser User? @relation("SystemParameterUpdatedBy", fields: [updatedById], references: [id])

  @@map("mst_system_parameters")
}

model BusinessParameter {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  pharmacyId  Int      @map("pharmacy_id")
  key         String
  value       String
  dataType    DataType @map("data_type")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")
  updatedById Int?     @map("updated_by_id")

  pharmacy      Pharmacy @relation(fields: [pharmacyId], references: [id])
  createdByUser User?    @relation("BusinessParameterCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?    @relation("BusinessParameterUpdatedBy", fields: [updatedById], references: [id])

  @@unique([pharmacyId, key])
  @@map("mst_business_parameters")
}

model Role {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  pharmacyId  Int?         @map("pharmacy_id")
  name        String
  type        PharmacyRole
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdById Int?         @map("created_by_id")
  updatedById Int?         @map("updated_by_id")
  deletedById Int?         @map("deleted_by_id")

  pharmacy        Pharmacy?        @relation(fields: [pharmacyId], references: [id])
  rolePermissions RolePermission[]
  placements  Placement[]
  createdByUser   User?            @relation("RoleCreatedBy", fields: [createdById], references: [id])
  updatedByUser   User?            @relation("RoleUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser   User?            @relation("RoleDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")
  updatedById Int?     @map("updated_by_id")

  rolePermissions RolePermission[]
  createdByUser   User?            @relation("PermissionCreatedBy", fields: [createdById], references: [id])
  updatedByUser   User?            @relation("PermissionUpdatedBy", fields: [updatedById], references: [id])

  @@unique([module, action])
  @@map("mst_permissions")
}

model RolePermission {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  roleId       Int      @map("role_id")
  permissionId Int      @map("permission_id")
  pharmacyId   Int?     @map("pharmacy_id")
  isEnabled    Boolean  @default(true) @map("is_enabled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdById  Int?     @map("created_by_id")
  updatedById  Int?     @map("updated_by_id")

  role          Role       @relation(fields: [roleId], references: [id])
  permission    Permission @relation(fields: [permissionId], references: [id])
  pharmacy      Pharmacy?  @relation(fields: [pharmacyId], references: [id])
  createdByUser User?      @relation("RolePermissionCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?      @relation("RolePermissionUpdatedBy", fields: [updatedById], references: [id])

  @@unique([roleId, permissionId, pharmacyId])
  @@map("mst_role_permissions")
}

// ── MST PHARMACY & USER ──────────────────────────────────

model Pharmacy {
  id           Int              @id @default(autoincrement())
  uuid         String           @unique @default(uuid())
  ownerId      Int              @map("owner_id")
  name         String
  code         String           @unique
  category     PharmacyCategory @default(APOTEK)
  address      String
  phone        String
  email        String?
  permitNumber String?          @map("permit_number")
  status       RecordStatus     @default(ACTIVE)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")
  createdById  Int?             @map("created_by_id")
  updatedById  Int?             @map("updated_by_id")
  deletedById  Int?             @map("deleted_by_id")

  owner                User                @relation("PharmacyOwner", fields: [ownerId], references: [id])
  lastSelectedByUsers  User[]              @relation("UserLastPharmacy")
  createdByUser        User?               @relation("PharmacyCreatedBy", fields: [createdById], references: [id])
  updatedByUser      User?               @relation("PharmacyUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser      User?               @relation("PharmacyDeletedBy", fields: [deletedById], references: [id])
  placements         Placement[]
  medicines          Medicine[]
  distributors       Distributor[]
  customers          Customer[]
  purchaseOrders     PurchaseOrder[]
  invoices           Invoice[]
  stocks             Stock[]
  stockMovements     StockMovement[]
  stockReturns       StockReturn[]
  stockDisposals     StockDisposal[]
  sales              Sale[]
  businessParameters BusinessParameter[]
  roles              Role[]
  rolePermissions    RolePermission[]
  medicineShapes     MedicineShape[]
  medicineTypes      MedicineType[]
  medicineClasses    MedicineClass[]
  @@map("mst_pharmacies")
}

model User {
  id           Int           @id @default(autoincrement())
  uuid         String        @unique @default(uuid())
  name         String
  email        String        @unique
  password     String
  phone                  String?       @map("phone")
  address                String?       @map("address")
  mustChangePassword     Boolean       @default(false) @map("must_change_password")
  platformRole           PlatformRole? @map("platform_role")
  lastSelectedPharmacyId Int?          @map("last_selected_pharmacy_id")
  failedLoginCount       Int           @default(0) @map("failed_login_count")
  lockedUntil            DateTime?     @map("locked_until")
  status                 RecordStatus  @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")
  createdById  Int?          @map("created_by_id")
  updatedById  Int?          @map("updated_by_id")
  deletedById  Int?          @map("deleted_by_id")

  // ── Self Relations ────────────────────────────────
  createdByUser User?  @relation("UserCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?  @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?  @relation("UserDeletedBy", fields: [deletedById], references: [id])
  usersCreated  User[] @relation("UserCreatedBy")
  usersUpdated  User[] @relation("UserUpdatedBy")
  usersDeleted  User[] @relation("UserDeletedBy")

  // ── Business Relations ────────────────────────────
  placements       Placement[]
  tokens               UserToken[]
  ownedPharmacies      Pharmacy[]     @relation("PharmacyOwner")
  lastSelectedPharmacy Pharmacy?      @relation("UserLastPharmacy", fields: [lastSelectedPharmacyId], references: [id])
  // purchaseOrders  PurchaseOrder[]
  // invoices        Invoice[]
  // stockReturns    StockReturn[]
  // stockDisposals  StockDisposal[]
  // sales           Sale[]
  // stockMovements  StockMovement[]

  // ── Audit: SystemParameter ────────────────────────
  systemParametersCreated SystemParameter[] @relation("SystemParameterCreatedBy")
  systemParametersUpdated SystemParameter[] @relation("SystemParameterUpdatedBy")

  // ── Audit: BusinessParameter ──────────────────────
  businessParametersCreated BusinessParameter[] @relation("BusinessParameterCreatedBy")
  businessParametersUpdated BusinessParameter[] @relation("BusinessParameterUpdatedBy")

  // ── Audit: Role ───────────────────────────────────
  rolesCreated Role[] @relation("RoleCreatedBy")
  rolesUpdated Role[] @relation("RoleUpdatedBy")
  rolesDeleted Role[] @relation("RoleDeletedBy")

  // ── Audit: Permission ─────────────────────────────
  permissionsCreated Permission[] @relation("PermissionCreatedBy")
  permissionsUpdated Permission[] @relation("PermissionUpdatedBy")

  // ── Audit: RolePermission ─────────────────────────
  rolePermissionsCreated RolePermission[] @relation("RolePermissionCreatedBy")
  rolePermissionsUpdated RolePermission[] @relation("RolePermissionUpdatedBy")

  // ── Audit: Pharmacy ───────────────────────────────
  pharmaciesCreated Pharmacy[] @relation("PharmacyCreatedBy")
  pharmaciesUpdated Pharmacy[] @relation("PharmacyUpdatedBy")
  pharmaciesDeleted Pharmacy[] @relation("PharmacyDeletedBy")

  // ── Audit: UserToken ──────────────────────────────
  userTokensCreated UserToken[] @relation("UserTokenCreatedBy")
  userTokensUpdated UserToken[] @relation("UserTokenUpdatedBy")

  // ── Audit: Placement ───────────────────────────
  placementsCreated Placement[] @relation("PlacementCreatedBy")
  placementsUpdated Placement[] @relation("PlacementUpdatedBy")
  placementsDeleted Placement[] @relation("PlacementDeletedBy")

  // ── Audit: License ────────────────────────────────
  licensesCreated License[] @relation("LicenseCreatedBy")
  licensesUpdated License[] @relation("LicenseUpdatedBy")
  licensesDeleted License[] @relation("LicenseDeletedBy")

  // ── Audit: MedicineShape ──────────────────────────
  medicineShapesCreated MedicineShape[] @relation("MedicineShapeCreatedBy")
  medicineShapesUpdated MedicineShape[] @relation("MedicineShapeUpdatedBy")
  medicineShapesDeleted MedicineShape[] @relation("MedicineShapeDeletedBy")

  // ── Audit: MedicineType ───────────────────────────
  medicineTypesCreated MedicineType[] @relation("MedicineTypeCreatedBy")
  medicineTypesUpdated MedicineType[] @relation("MedicineTypeUpdatedBy")
  medicineTypesDeleted MedicineType[] @relation("MedicineTypeDeletedBy")

  // ── Audit: MedicineClass ──────────────────────────
  medicineClassesCreated MedicineClass[] @relation("MedicineClassCreatedBy")
  medicineClassesUpdated MedicineClass[] @relation("MedicineClassUpdatedBy")
  medicineClassesDeleted MedicineClass[] @relation("MedicineClassDeletedBy")

  // ── Audit: Medicine ───────────────────────────────
  medicinesCreated Medicine[] @relation("MedicineCreatedBy")
  medicinesUpdated Medicine[] @relation("MedicineUpdatedBy")
  medicinesDeleted Medicine[] @relation("MedicineDeletedBy")

  // ── Audit: MedicineIngredient ─────────────────────
  medicineIngredientsCreated MedicineIngredient[] @relation("MedicineIngredientCreatedBy")
  medicineIngredientsUpdated MedicineIngredient[] @relation("MedicineIngredientUpdatedBy")

  // ── Audit: Distributor ────────────────────────────
  distributorsCreated Distributor[] @relation("DistributorCreatedBy")
  distributorsUpdated Distributor[] @relation("DistributorUpdatedBy")
  distributorsDeleted Distributor[] @relation("DistributorDeletedBy")

  // ── Audit: Customer ───────────────────────────────
  customersCreated Customer[] @relation("CustomerCreatedBy")
  customersUpdated Customer[] @relation("CustomerUpdatedBy")
  customersDeleted Customer[] @relation("CustomerDeletedBy")

  // ── Audit: PurchaseOrder ──────────────────────────
  purchaseOrdersCreated PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  purchaseOrdersUpdated PurchaseOrder[] @relation("PurchaseOrderUpdatedBy")
  purchaseOrdersDeleted PurchaseOrder[] @relation("PurchaseOrderDeletedBy")

  // ── Audit: PurchaseOrderDetail ────────────────────
  purchaseOrderDetailsCreated PurchaseOrderDetail[] @relation("PurchaseOrderDetailCreatedBy")
  purchaseOrderDetailsUpdated PurchaseOrderDetail[] @relation("PurchaseOrderDetailUpdatedBy")
  purchaseOrderDetailsDeleted PurchaseOrderDetail[] @relation("PurchaseOrderDetailDeletedBy")

  // ── Audit: Invoice ────────────────────────────────
  invoicesCreated Invoice[] @relation("InvoiceCreatedBy")
  invoicesUpdated Invoice[] @relation("InvoiceUpdatedBy")
  invoicesDeleted Invoice[] @relation("InvoiceDeletedBy")

  // ── Audit: InvoiceDetail ──────────────────────────
  invoiceDetailsCreated InvoiceDetail[] @relation("InvoiceDetailCreatedBy")
  invoiceDetailsUpdated InvoiceDetail[] @relation("InvoiceDetailUpdatedBy")

  // ── Audit: InvoicePayment ─────────────────────────
  invoicePaymentsCreated InvoicePayment[] @relation("InvoicePaymentCreatedBy")
  invoicePaymentsUpdated InvoicePayment[] @relation("InvoicePaymentUpdatedBy")

  // ── Audit: InvoicePaymentHistory ──────────────────
  invoicePaymentHistoriesCreated InvoicePaymentHistory[] @relation("InvoicePaymentHistoryCreatedBy")
  invoicePaymentHistoriesUpdated InvoicePaymentHistory[] @relation("InvoicePaymentHistoryUpdatedBy")

  // ── Audit: Stock ──────────────────────────────────
  stocksCreated Stock[] @relation("StockCreatedBy")
  stocksUpdated Stock[] @relation("StockUpdatedBy")

  // ── Audit: StockDetail ────────────────────────────
  stockDetailsCreated StockDetail[] @relation("StockDetailCreatedBy")
  stockDetailsUpdated StockDetail[] @relation("StockDetailUpdatedBy")

  // ── Audit: StockMovement ──────────────────────────
  stockMovementsCreated StockMovement[] @relation("StockMovementCreatedBy")
  stockMovementsUpdated StockMovement[] @relation("StockMovementUpdatedBy")

  // ── Audit: StockReturn ────────────────────────────
  stockReturnsCreated StockReturn[] @relation("StockReturnCreatedBy")
  stockReturnsUpdated StockReturn[] @relation("StockReturnUpdatedBy")
  stockReturnsDeleted StockReturn[] @relation("StockReturnDeletedBy")

  // ── Audit: StockReturnDetail ──────────────────────
  stockReturnDetailsCreated StockReturnDetail[] @relation("StockReturnDetailCreatedBy")
  stockReturnDetailsUpdated StockReturnDetail[] @relation("StockReturnDetailUpdatedBy")

  // ── Audit: StockDisposal ──────────────────────────
  stockDisposalsCreated StockDisposal[] @relation("StockDisposalCreatedBy")
  stockDisposalsUpdated StockDisposal[] @relation("StockDisposalUpdatedBy")
  stockDisposalsDeleted StockDisposal[] @relation("StockDisposalDeletedBy")

  // ── Audit: StockDisposalDetail ────────────────────
  stockDisposalDetailsCreated StockDisposalDetail[] @relation("StockDisposalDetailCreatedBy")
  stockDisposalDetailsUpdated StockDisposalDetail[] @relation("StockDisposalDetailUpdatedBy")

  // ── Audit: Sale ───────────────────────────────────
  salesCreated Sale[] @relation("SaleCreatedBy")
  salesUpdated Sale[] @relation("SaleUpdatedBy")
  salesDeleted Sale[] @relation("SaleDeletedBy")

  // ── Audit: SaleDetail ─────────────────────────────
  saleDetailsCreated SaleDetail[] @relation("SaleDetailCreatedBy")
  saleDetailsUpdated SaleDetail[] @relation("SaleDetailUpdatedBy")

  // ── Audit: SalePayment ────────────────────────────
  salePaymentsCreated SalePayment[] @relation("SalePaymentCreatedBy")
  salePaymentsUpdated SalePayment[] @relation("SalePaymentUpdatedBy")

  // ── Audit: SalePaymentHistory ─────────────────────
  salePaymentHistoriesCreated SalePaymentHistory[] @relation("SalePaymentHistoryCreatedBy")
  salePaymentHistoriesUpdated SalePaymentHistory[] @relation("SalePaymentHistoryUpdatedBy")

  // ── Signing ───────────────────────────────────────────
  purchaseOrdersSigned PurchaseOrder[] @relation("PurchaseOrderSignedBy")
  invoicesSigned       Invoice[]       @relation("InvoiceSignedBy")
  stockReturnsSigned   StockReturn[]   @relation("StockReturnSignedBy")
  stockDisposalsSigned StockDisposal[] @relation("StockDisposalSignedBy")

  @@map("mst_users")
}

model UserToken {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  userId       Int      @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdById  Int?     @map("created_by_id")
  updatedById  Int?     @map("updated_by_id")

  user          User  @relation(fields: [userId], references: [id])
  createdByUser User? @relation("UserTokenCreatedBy", fields: [createdById], references: [id])
  updatedByUser User? @relation("UserTokenUpdatedBy", fields: [updatedById], references: [id])

  @@map("mst_user_tokens")
}

model Placement {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  userId      Int          @map("user_id")
  pharmacyId  Int          @map("pharmacy_id")
  roleId      Int          @map("role_id")
  joinedAt    DateTime     @default(now()) @map("joined_at")
  leftAt      DateTime?    @map("left_at")
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdById Int?         @map("created_by_id")
  updatedById Int?         @map("updated_by_id")
  deletedById Int?         @map("deleted_by_id")

  user          User      @relation(fields: [userId], references: [id])
  pharmacy      Pharmacy  @relation(fields: [pharmacyId], references: [id])
  role          Role      @relation(fields: [roleId], references: [id])
  licenses      License[]
  createdByUser User?     @relation("PlacementCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?     @relation("PlacementUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?     @relation("PlacementDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_placements")
}

model License {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(uuid())
  placementId     Int          @map("user_pharmacy_id")
  licenseNumber   String       @map("license_number")
  validFrom       DateTime     @map("valid_from")
  validUntil      DateTime     @map("valid_until")
  status          RecordStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdById     Int?         @map("created_by_id")
  updatedById     Int?         @map("updated_by_id")
  deletedById     Int?         @map("deleted_by_id")

  placement      Placement    @relation(fields: [placementId], references: [id])
  createdByUser User?        @relation("LicenseCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?        @relation("LicenseUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?        @relation("LicenseDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_licenses")
}

// ── MST MEDICINE ─────────────────────────────────────────

model MedicineShape {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  pharmacyId  Int?         @map("pharmacy_id")
  name        String
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdById Int?         @map("created_by_id")
  updatedById Int?         @map("updated_by_id")
  deletedById Int?         @map("deleted_by_id")

  pharmacy      Pharmacy?  @relation(fields: [pharmacyId], references: [id])
  medicines     Medicine[]
  createdByUser User?      @relation("MedicineShapeCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?      @relation("MedicineShapeUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?      @relation("MedicineShapeDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_medicine_shapes")
}

model MedicineType {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  pharmacyId  Int?         @map("pharmacy_id")
  name        String
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdById Int?         @map("created_by_id")
  updatedById Int?         @map("updated_by_id")
  deletedById Int?         @map("deleted_by_id")

  pharmacy      Pharmacy?  @relation(fields: [pharmacyId], references: [id])
  medicines     Medicine[]
  createdByUser User?      @relation("MedicineTypeCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?      @relation("MedicineTypeUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?      @relation("MedicineTypeDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_medicine_types")
}

model MedicineClass {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  pharmacyId  Int?         @map("pharmacy_id")
  name        String
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdById Int?         @map("created_by_id")
  updatedById Int?         @map("updated_by_id")
  deletedById Int?         @map("deleted_by_id")

  pharmacy      Pharmacy?  @relation(fields: [pharmacyId], references: [id])
  medicines     Medicine[]
  createdByUser User?      @relation("MedicineClassCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?      @relation("MedicineClassUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?      @relation("MedicineClassDeletedBy", fields: [deletedById], references: [id])

  @@map("mst_medicine_classes")
}

model Medicine {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(uuid())
  pharmacyId      Int          @map("pharmacy_id")
  name            String
  shapeId         Int          @map("shape_id")
  typeId          Int          @map("type_id")
  medicineClassId Int          @map("medicine_class_id")
  unit            String
  status          RecordStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdById     Int?         @map("created_by_id")
  updatedById     Int?         @map("updated_by_id")
  deletedById     Int?         @map("deleted_by_id")

  pharmacy             Pharmacy              @relation(fields: [pharmacyId], references: [id])
  shape                MedicineShape         @relation(fields: [shapeId], references: [id])
  type                 MedicineType          @relation(fields: [typeId], references: [id])
  medicineClass        MedicineClass         @relation(fields: [medicineClassId], references: [id])
  createdByUser        User?                 @relation("MedicineCreatedBy", fields: [createdById], references: [id])
  updatedByUser        User?                 @relation("MedicineUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser        User?                 @relation("MedicineDeletedBy", fields: [deletedById], references: [id])
  ingredients          MedicineIngredient[]
  purchaseOrderDetails PurchaseOrderDetail[]
  invoiceDetails       InvoiceDetail[]
  stocks               Stock[]
  stockMovements       StockMovement[]
  stockReturnDetails   StockReturnDetail[]
  stockDisposalDetails StockDisposalDetail[]
  saleDetails          SaleDetail[]

  @@map("mst_medicines")
}

model MedicineIngredient {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  medicineId  Int      @map("medicine_id")
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")
  updatedById Int?     @map("updated_by_id")

  medicine      Medicine @relation(fields: [medicineId], references: [id])
  createdByUser User?    @relation("MedicineIngredientCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?    @relation("MedicineIngredientUpdatedBy", fields: [updatedById], references: [id])

  @@map("mst_medicine_ingredients")
}

// ── MST DISTRIBUTOR & CUSTOMER ───────────────────────────

model Distributor {
  id            Int          @id @default(autoincrement())
  uuid          String       @unique @default(uuid())
  pharmacyId    Int          @map("pharmacy_id")
  name          String
  phone         String
  email         String?
  address       String?
  contactPerson String?      @map("contact_person")
  permitNumber  String?      @map("permit_number")
  description   String?
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")
  createdById   Int?         @map("created_by_id")
  updatedById   Int?         @map("updated_by_id")
  deletedById   Int?         @map("deleted_by_id")

  pharmacy       Pharmacy        @relation(fields: [pharmacyId], references: [id])
  createdByUser  User?           @relation("DistributorCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?           @relation("DistributorUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser  User?           @relation("DistributorDeletedBy", fields: [deletedById], references: [id])
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  stockDetails   StockDetail[]
  stockReturns   StockReturn[]

  @@map("mst_distributors")
}

model Customer {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  pharmacyId  Int          @map("pharmacy_id")
  name        String
  phone       String?
  address     String?
  description String?
  isWalkIn    Boolean      @default(false) @map("is_walk_in")
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdById Int?         @map("created_by_id")
  updatedById Int?         @map("updated_by_id")
  deletedById Int?         @map("deleted_by_id")

  pharmacy      Pharmacy @relation(fields: [pharmacyId], references: [id])
  createdByUser User?    @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?    @relation("CustomerUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?    @relation("CustomerDeletedBy", fields: [deletedById], references: [id])
  sales         Sale[]

  // @@unique([pharmacyId, phone])
  @@map("mst_customers")
}

// ── TRX PURCHASE ORDER ───────────────────────────────────

model PurchaseOrder {
  id                 Int                 @id @default(autoincrement())
  uuid               String              @unique @default(uuid())
  pharmacyId         Int                 @map("pharmacy_id")
  distributorId      Int                 @map("distributor_id")
  signedById         Int?                @map("signed_by_id")
  orderNumber        String              @unique @map("order_number")
  status             PurchaseOrderStatus @default(DRAFT)
  description        String?
  cancellationReason String?             @map("cancellation_reason")
  orderedAt          DateTime            @default(now()) @map("ordered_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  createdById        Int?                @map("created_by_id")
  updatedById        Int?                @map("updated_by_id")
  deletedById        Int?                @map("deleted_by_id")

  pharmacy         Pharmacy              @relation(fields: [pharmacyId], references: [id])
  distributor      Distributor           @relation(fields: [distributorId], references: [id])
  signedByUser     User?                 @relation("PurchaseOrderSignedBy", fields: [signedById], references: [id])
  createdByUser    User?                 @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  updatedByUser    User?                 @relation("PurchaseOrderUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser    User?                 @relation("PurchaseOrderDeletedBy", fields: [deletedById], references: [id])
  details          PurchaseOrderDetail[]
  invoices         Invoice[]

  @@map("trx_purchase_orders")
}

model PurchaseOrderDetail {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid())
  purchaseOrderId Int       @map("purchase_order_id")
  medicineId      Int       @map("medicine_id")
  quantity        Int
  unit            String
  description     String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdById     Int?      @map("created_by_id")
  updatedById     Int?      @map("updated_by_id")
  deletedById     Int?      @map("deleted_by_id")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  medicine      Medicine      @relation(fields: [medicineId], references: [id])
  createdByUser User?         @relation("PurchaseOrderDetailCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?         @relation("PurchaseOrderDetailUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?         @relation("PurchaseOrderDetailDeletedBy", fields: [deletedById], references: [id])

  @@map("trx_purchase_order_details")
}

// ── TRX INVOICE ──────────────────────────────────────────

model Invoice {
  id              Int           @id @default(autoincrement())
  uuid            String        @unique @default(uuid())
  pharmacyId      Int           @map("pharmacy_id")
  distributorId   Int           @map("distributor_id")
  purchaseOrderId Int?          @map("purchase_order_id")
  signedById      Int?          @map("signed_by_id")
  invoiceNumber   String        @unique @map("invoice_number")
  paymentStatus   PaymentStatus @default(UNPAID) @map("payment_status")
  invoiceDate     DateTime      @map("invoice_date")
  dueDate         DateTime?     @map("due_date")
  totalAmount     Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  description     String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  createdById     Int?          @map("created_by_id")
  updatedById     Int?          @map("updated_by_id")
  deletedById     Int?          @map("deleted_by_id")

  pharmacy         Pharmacy         @relation(fields: [pharmacyId], references: [id])
  distributor      Distributor      @relation(fields: [distributorId], references: [id])
  purchaseOrder    PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  signedByUser     User?            @relation("InvoiceSignedBy", fields: [signedById], references: [id])
  createdByUser    User?            @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  updatedByUser    User?            @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser    User?            @relation("InvoiceDeletedBy", fields: [deletedById], references: [id])
  details          InvoiceDetail[]
  payments         InvoicePayment[]

  @@map("trx_invoices")
}

model InvoiceDetail {
  id                 Int      @id @default(autoincrement())
  uuid               String   @unique @default(uuid())
  invoiceId          Int      @map("invoice_id")
  medicineId         Int      @map("medicine_id")
  batchNumber        String   @map("batch_number")
  expiryDate         DateTime @map("expiry_date")
  quantityBox        Int      @map("quantity_box")
  quantityPerBox     Int      @map("quantity_per_box")
  quantityPieces     Int      @map("quantity_pieces")
  price              Decimal  @db.Decimal(12, 2)
  discountPercentage Decimal  @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  discountAmount     Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  finalPrice         Decimal  @map("final_price") @db.Decimal(12, 2)
  totalAmount        Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  createdById        Int?     @map("created_by_id")
  updatedById        Int?     @map("updated_by_id")

  invoice        Invoice         @relation(fields: [invoiceId], references: [id])
  medicine       Medicine        @relation(fields: [medicineId], references: [id])
  createdByUser  User?           @relation("InvoiceDetailCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?           @relation("InvoiceDetailUpdatedBy", fields: [updatedById], references: [id])
  stockDetail    StockDetail?
  stockMovements StockMovement[]

  @@map("trx_invoice_details")
}

model InvoicePayment {
  id            Int           @id @default(autoincrement())
  uuid          String        @unique @default(uuid())
  invoiceId     Int           @map("invoice_id")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdById   Int?          @map("created_by_id")
  updatedById   Int?          @map("updated_by_id")

  invoice       Invoice                 @relation(fields: [invoiceId], references: [id])
  createdByUser User?                   @relation("InvoicePaymentCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?                   @relation("InvoicePaymentUpdatedBy", fields: [updatedById], references: [id])
  history       InvoicePaymentHistory[]

  @@map("trx_invoice_payments")
}

model InvoicePaymentHistory {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  invoicePaymentId Int           @map("invoice_payment_id")
  amount           Decimal       @db.Decimal(12, 2)
  paymentMethod    PaymentMethod @map("payment_method")
  paymentDate      DateTime      @map("payment_date")
  description      String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  createdById      Int?          @map("created_by_id")
  updatedById      Int?          @map("updated_by_id")

  invoicePayment InvoicePayment @relation(fields: [invoicePaymentId], references: [id])
  createdByUser  User?          @relation("InvoicePaymentHistoryCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?          @relation("InvoicePaymentHistoryUpdatedBy", fields: [updatedById], references: [id])

  @@map("trx_invoice_payment_history")
}

// ── INV STOCK ────────────────────────────────────────────

model Stock {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid())
  pharmacyId      Int      @map("pharmacy_id")
  medicineId      Int      @map("medicine_id")
  totalPieces     Int      @map("total_pieces")
  reorderLevel    Int      @default(0) @map("reorder_level")
  basePrice       Decimal  @map("base_price") @db.Decimal(12, 2)
  calculatedPrice Decimal  @map("calculated_price") @db.Decimal(12, 2)
  sellingPrice    Decimal? @map("selling_price") @db.Decimal(12, 2)
  isManualPrice   Boolean  @default(false) @map("is_manual_price")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     Int?     @map("created_by_id")
  updatedById     Int?     @map("updated_by_id")

  pharmacy       Pharmacy        @relation(fields: [pharmacyId], references: [id])
  medicine       Medicine        @relation(fields: [medicineId], references: [id])
  createdByUser  User?           @relation("StockCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?           @relation("StockUpdatedBy", fields: [updatedById], references: [id])
  details        StockDetail[]
  stockMovements StockMovement[]

  @@unique([pharmacyId, medicineId])
  @@map("inv_stocks")
}

model StockDetail {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid())
  stockId         Int      @map("stock_id")
  distributorId   Int      @map("distributor_id")
  invoiceDetailId Int      @unique @map("invoice_detail_id")
  batchNumber     String   @map("batch_number")
  barcode         String?  @unique
  expiryDate      DateTime @map("expiry_date")
  quantityPieces  Int      @map("quantity_pieces")
  quantityBox     Int      @map("quantity_box")
  quantityPerBox  Int      @map("quantity_per_box")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     Int?     @map("created_by_id")
  updatedById     Int?     @map("updated_by_id")

  stock                Stock                 @relation(fields: [stockId], references: [id])
  distributor          Distributor           @relation(fields: [distributorId], references: [id])
  invoiceDetail        InvoiceDetail         @relation(fields: [invoiceDetailId], references: [id])
  createdByUser        User?                 @relation("StockDetailCreatedBy", fields: [createdById], references: [id])
  updatedByUser        User?                 @relation("StockDetailUpdatedBy", fields: [updatedById], references: [id])
  stockMovements       StockMovement[]
  stockReturnDetails   StockReturnDetail[]
  stockDisposalDetails StockDisposalDetail[]
  saleDetails          SaleDetail[]

  @@map("inv_stock_details")
}

model StockMovement {
  id                    Int                 @id @default(autoincrement())
  uuid                  String              @unique @default(uuid())
  pharmacyId            Int                 @map("pharmacy_id")
  medicineId            Int                 @map("medicine_id")
  stockId               Int                 @map("stock_id")
  stockDetailId         Int                 @map("stock_detail_id")
  type                  StockMovementType
  reason                StockMovementReason
  quantity              Int
  quantityBefore        Int                 @map("quantity_before")
  quantityAfter         Int                 @map("quantity_after")
  description           String?
  invoiceDetailId       Int?                @map("invoice_detail_id")
  saleDetailId          Int?                @map("sale_detail_id")
  stockReturnDetailId   Int?                @map("stock_return_detail_id")
  stockDisposalDetailId Int?                @map("stock_disposal_detail_id")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  createdById           Int?                @map("created_by_id")
  updatedById           Int?                @map("updated_by_id")

  pharmacy            Pharmacy             @relation(fields: [pharmacyId], references: [id])
  medicine            Medicine             @relation(fields: [medicineId], references: [id])
  stock               Stock                @relation(fields: [stockId], references: [id])
  stockDetail         StockDetail          @relation(fields: [stockDetailId], references: [id])
  invoiceDetail       InvoiceDetail?       @relation(fields: [invoiceDetailId], references: [id])
  saleDetail          SaleDetail?          @relation(fields: [saleDetailId], references: [id])
  stockReturnDetail   StockReturnDetail?   @relation(fields: [stockReturnDetailId], references: [id])
  stockDisposalDetail StockDisposalDetail? @relation(fields: [stockDisposalDetailId], references: [id])
  createdByUser       User?                @relation("StockMovementCreatedBy", fields: [createdById], references: [id])
  updatedByUser       User?                @relation("StockMovementUpdatedBy", fields: [updatedById], references: [id])

  @@map("inv_stock_movements")
}

// ── TRX STOCK RETURN ─────────────────────────────────────

model StockReturn {
  id                 Int               @id @default(autoincrement())
  uuid               String            @unique @default(uuid())
  pharmacyId         Int               @map("pharmacy_id")
  distributorId      Int               @map("distributor_id")
  signedById         Int?              @map("signed_by_id")
  returnNumber       String            @unique @map("return_number")
  status             StockReturnStatus @default(DRAFT)
  description        String?
  cancellationReason String?           @map("cancellation_reason")
  returnedAt         DateTime?         @map("returned_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")
  createdById        Int?              @map("created_by_id")
  updatedById        Int?              @map("updated_by_id")
  deletedById        Int?              @map("deleted_by_id")

  pharmacy         Pharmacy            @relation(fields: [pharmacyId], references: [id])
  distributor      Distributor         @relation(fields: [distributorId], references: [id])
  signedByUser     User?               @relation("StockReturnSignedBy", fields: [signedById], references: [id])
  createdByUser    User?               @relation("StockReturnCreatedBy", fields: [createdById], references: [id])
  updatedByUser    User?               @relation("StockReturnUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser    User?               @relation("StockReturnDeletedBy", fields: [deletedById], references: [id])
  details          StockReturnDetail[]

  @@map("trx_stock_returns")
}

model StockReturnDetail {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique @default(uuid())
  stockReturnId  Int      @map("stock_return_id")
  medicineId     Int      @map("medicine_id")
  stockDetailId  Int      @map("stock_detail_id")
  quantityPieces Int      @map("quantity_pieces")
  quantityBox    Int      @map("quantity_box")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdById    Int?     @map("created_by_id")
  updatedById    Int?     @map("updated_by_id")

  stockReturn    StockReturn     @relation(fields: [stockReturnId], references: [id])
  medicine       Medicine        @relation(fields: [medicineId], references: [id])
  stockDetail    StockDetail     @relation(fields: [stockDetailId], references: [id])
  createdByUser  User?           @relation("StockReturnDetailCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?           @relation("StockReturnDetailUpdatedBy", fields: [updatedById], references: [id])
  stockMovements StockMovement[]

  @@map("trx_stock_return_details")
}

// ── TRX STOCK DISPOSAL ───────────────────────────────────

model StockDisposal {
  id                 Int                 @id @default(autoincrement())
  uuid               String              @unique @default(uuid())
  pharmacyId         Int                 @map("pharmacy_id")
  signedById         Int?                @map("signed_by_id")
  disposalNumber     String              @unique @map("disposal_number")
  status             StockDisposalStatus @default(DRAFT)
  description        String?
  cancellationReason String?             @map("cancellation_reason")
  disposedAt         DateTime?           @map("disposed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  createdById        Int?                @map("created_by_id")
  updatedById        Int?                @map("updated_by_id")
  deletedById        Int?                @map("deleted_by_id")

  pharmacy         Pharmacy              @relation(fields: [pharmacyId], references: [id])
  signedByUser     User?                 @relation("StockDisposalSignedBy", fields: [signedById], references: [id])
  createdByUser    User?                 @relation("StockDisposalCreatedBy", fields: [createdById], references: [id])
  updatedByUser    User?                 @relation("StockDisposalUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser    User?                 @relation("StockDisposalDeletedBy", fields: [deletedById], references: [id])
  details          StockDisposalDetail[]

  @@map("trx_stock_disposals")
}

model StockDisposalDetail {
  id              Int            @id @default(autoincrement())
  uuid            String         @unique @default(uuid())
  stockDisposalId Int            @map("stock_disposal_id")
  medicineId      Int            @map("medicine_id")
  stockDetailId   Int            @map("stock_detail_id")
  quantityPieces  Int            @map("quantity_pieces")
  quantityBox     Int            @map("quantity_box")
  reason          DisposalReason
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  createdById     Int?           @map("created_by_id")
  updatedById     Int?           @map("updated_by_id")

  stockDisposal  StockDisposal   @relation(fields: [stockDisposalId], references: [id])
  medicine       Medicine        @relation(fields: [medicineId], references: [id])
  stockDetail    StockDetail     @relation(fields: [stockDetailId], references: [id])
  createdByUser  User?           @relation("StockDisposalDetailCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?           @relation("StockDisposalDetailUpdatedBy", fields: [updatedById], references: [id])
  stockMovements StockMovement[]

  @@map("trx_stock_disposal_details")
}

// ── TRX SALES ────────────────────────────────────────────

model Sale {
  id          Int        @id @default(autoincrement())
  uuid        String     @unique @default(uuid())
  pharmacyId  Int        @map("pharmacy_id")
  customerId  Int        @map("customer_id")
  saleNumber  String     @unique @map("sale_number")
  saleType    SaleType   @default(CASH) @map("sale_type")
  status      SaleStatus @default(COMPLETED)
  totalAmount   Decimal   @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  taxPercentage Decimal   @default(0) @map("tax_percentage") @db.Decimal(5, 2)
  taxAmount     Decimal   @default(0) @map("tax_amount") @db.Decimal(12, 2)
  dueDate       DateTime? @map("due_date")
  description   String?
  soldAt        DateTime  @default(now()) @map("sold_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")
  createdById Int?       @map("created_by_id")
  updatedById Int?       @map("updated_by_id")
  deletedById Int?       @map("deleted_by_id")

  pharmacy      Pharmacy     @relation(fields: [pharmacyId], references: [id])
  customer      Customer     @relation(fields: [customerId], references: [id])
  createdByUser User?        @relation("SaleCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?        @relation("SaleUpdatedBy", fields: [updatedById], references: [id])
  deletedByUser User?        @relation("SaleDeletedBy", fields: [deletedById], references: [id])
  details       SaleDetail[]
  payment       SalePayment?

  @@map("trx_sales")
}

model SaleDetail {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique @default(uuid())
  saleId         Int      @map("sale_id")
  medicineId     Int      @map("medicine_id")
  stockDetailId  Int      @map("stock_detail_id")
  quantityPieces Int      @map("quantity_pieces")
  quantityBox    Int      @map("quantity_box")
  isFefoOverride Boolean  @default(false) @map("is_fefo_override")
  sellingPrice   Decimal  @map("selling_price") @db.Decimal(12, 2)
  discount       Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdById    Int?     @map("created_by_id")
  updatedById    Int?     @map("updated_by_id")

  sale           Sale            @relation(fields: [saleId], references: [id])
  medicine       Medicine        @relation(fields: [medicineId], references: [id])
  stockDetail    StockDetail     @relation(fields: [stockDetailId], references: [id])
  createdByUser  User?           @relation("SaleDetailCreatedBy", fields: [createdById], references: [id])
  updatedByUser  User?           @relation("SaleDetailUpdatedBy", fields: [updatedById], references: [id])
  stockMovements StockMovement[]

  @@map("trx_sale_details")
}

model SalePayment {
  id            Int           @id @default(autoincrement())
  uuid          String        @unique @default(uuid())
  saleId        Int           @unique @map("sale_id")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdById   Int?          @map("created_by_id")
  updatedById   Int?          @map("updated_by_id")

  sale          Sale                 @relation(fields: [saleId], references: [id])
  createdByUser User?                @relation("SalePaymentCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?                @relation("SalePaymentUpdatedBy", fields: [updatedById], references: [id])
  history       SalePaymentHistory[]

  @@map("trx_sale_payments")
}

model SalePaymentHistory {
  id            Int           @id @default(autoincrement())
  uuid          String        @unique @default(uuid())
  salePaymentId Int           @map("sale_payment_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentDate   DateTime      @map("payment_date")
  description   String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdById   Int?          @map("created_by_id")
  updatedById   Int?          @map("updated_by_id")

  salePayment   SalePayment @relation(fields: [salePaymentId], references: [id])
  createdByUser User?       @relation("SalePaymentHistoryCreatedBy", fields: [createdById], references: [id])
  updatedByUser User?       @relation("SalePaymentHistoryUpdatedBy", fields: [updatedById], references: [id])

  @@map("trx_sale_payment_history")
}
